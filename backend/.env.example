# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# DATABASE & STORAGE
# ============================================

# Database URL
DATABASE_URL=sqlite:///./player_data.db

# Path to player_data directory (containing February_10/, etc.)
# Relative to backend/ directory, or absolute path
DATA_PATH=../player_data

# Path to minimap images directory
MAPS_PATH=../player_data/minimaps

# SQLite database file location
DB_PATH=./cache.db

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server host and port
HOST=0.0.0.0
PORT=8000

# Number of worker processes
WORKERS=4

# ============================================
# CORS & SECURITY
# ============================================

# CORS allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============================================
# LOGGING & DEBUG
# ============================================

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Python STDOUT buffering
PYTHONUNBUFFERED=1

# Debug mode (true/false)
DEBUG=false

# Auto-reload on file changes (development only)
RELOAD=false

# ============================================
# CACHING
# ============================================

# Enable result caching
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================
# API CONFIGURATION
# ============================================

# API metadata
API_TITLE=Player Journey Visualization API
API_VERSION=1.0.0
API_DESCRIPTION=API for player journey visualization data
# ============================================

# Enable debug mode (auto-reload, verbose errors)
# Set to False for production
DEBUG=True

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================

# Frontend URLs that can access this API
# For development, localhost:3000 is included by default
# For production, add your Vercel domain
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.vercel.app

# ============================================
# CACHING & PERFORMANCE
# ============================================

# Maximum size of in-memory cache (MB)
# Set based on available server RAM
CACHE_MAX_SIZE_MB=500

# Heatmap cache expiration time (hours)
# Heatmaps are expensive to compute; cache them for a day by default
HEATMAP_CACHE_TTL_HOURS=24

# Batch size for file loading
# Higher = faster but uses more memory
BATCH_SIZE=100

# ============================================
# OPTIONAL: Production Overrides
# ============================================

# For Render.com production:
# DEBUG=False
# LOG_LEVEL=WARNING
# DB_PATH=/tmp/cache.db
# CACHE_MAX_SIZE_MB=1000
