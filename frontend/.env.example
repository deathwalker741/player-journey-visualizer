# Frontend Environment Configuration
# Copy this file to .env.local and update values for your environment

# ============================================
# API CONFIGURATION
# ============================================

# Backend API base URL
# Development: http://localhost:8000
# Production: https://your-backend-domain.com
REACT_APP_API_URL=http://localhost:8000

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Application name and version
REACT_APP_APP_NAME=Player Journey Visualization
REACT_APP_APP_VERSION=1.0.0

# Build environment
NODE_ENV=development

# ============================================
# FEATURE FLAGS
# ============================================

# Enable heatmap visualization
REACT_APP_ENABLE_HEATMAPS=true

# Enable timeline playback controls
REACT_APP_ENABLE_TIMELINE=true

# Enable filter controls
REACT_APP_ENABLE_FILTERS=true

# ============================================
# MAP CONFIGURATION
# ============================================

# Default map zoom level
REACT_APP_MAP_DEFAULT_ZOOM=8

# Default map center coordinates
REACT_APP_MAP_DEFAULT_CENTER_LAT=512
REACT_APP_MAP_DEFAULT_CENTER_LON=512

# ============================================
# UI CONFIGURATION
# ============================================

# Enable dark mode support
REACT_APP_ENABLE_DARK_MODE=true

# Enable CSS animations
REACT_APP_ANIMATION_ENABLED=true

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================

# Data cache TTL in seconds
REACT_APP_DATA_CACHE_TTL=3600

# Maximum number of markers to render at once
REACT_APP_MAX_MARKERS_VISIBLE=10000

# ============================================
# LOGGING
# ============================================

# Logging level (debug, info, warning, error)
REACT_APP_LOG_LEVEL=info

REACT_APP_API_URL=http://localhost:8000

# Mapbox token for map rendering (optional, Deck.gl can work without it)
# REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# ============================================
# BUILD CONFIGURATION
# ============================================

# Disable browser auto-opening during npm start
# BROWSER=none

# Set to 'development' for verbose logging
# REACT_APP_LOG_LEVEL=development# ============================================
# DEBUG & DEVELOPMENT
# ============================================

# Enable debug logging in console
# REACT_APP_DEBUG=true

# ============================================
# OPTIONAL: Production Overrides
# ============================================

# For Vercel production:
# REACT_APP_API_URL=https://player-journey-api.onrender.com/api
# REACT_APP_DEBUG=false

# CI/CD environments (automatically set by Vercel)
# CI=true
